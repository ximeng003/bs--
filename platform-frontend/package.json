{
  "name": "platform-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "node ./node_modules/eslint/bin/eslint.js \"src/**/*.{ts,tsx,vue}\" --max-warnings=0",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js \"src/**/*.{ts,tsx,vue}\" --fix",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write \"src/**/*.{ts,tsx,vue,css,scss}\"",
    "typecheck": "vue-tsc -b",
    "check": "node scripts/verify.cjs"
  },
  "dependencies": {
    "@vueuse/core": "^14.1.0",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "echarts": "^5.6.0",
    "lucide-vue-next": "^0.469.0",
    "pinia": "^3.0.4",
    "tailwind-merge": "^2.6.0",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-vue": "^9.33.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0"
  }
}
